{
  "name": "@formspark/use-formspark",
  "description": "React hooks for Formspark",
  "private": false,
  "version": "1.0.0",
  "author": "Bjorn Krols (https://formspark.io)",
  "license": "MIT",
  "keywords": [
    "formspark",
    "react",
    "react-hook"
  ],
  "homepage": "https://github.com/formspark/use-formspark#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/formspark/use-formspark.git"
  },
  "bugs": {
    "url": "https://github.com/formspark/use-formspark/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --clean",
    "lint": "tsc --noEmit",
    "prepare": "husky install",
    "start": "tsup src/index.ts --dts --format esm,cjs --watch"
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "husky": "^8.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  }
}
